# Community Gardener — keep PII and secrets out of this public harness repo.
# The harness ships generic. YOUR community lives in config.local.js, data/,
# persona.local.json, and memory/ — none of which is ever committed.

# Your community (never commit)
config.local.js
persona.local.json
data/*
!data/protect.example.json
memory/*.md
!memory/SCHEMA.md

# Linked WhatsApp session + browser cache
.wwebjs_auth/
.wwebjs_cache/

# Node / logs / OS / env
node_modules/
package-lock.json
yarn.lock
*.log
.DS_Store
.env

# Legacy local-only tooling dir (holds PII; never tracked)
whatsapp/
